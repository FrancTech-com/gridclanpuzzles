# ============================================================
# GridClan Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

# ── PostgreSQL (Supabase) ─────────────────────────────────────
DB_HOST=your-project.pooler.supabase.com
DB_NAME=postgres
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_db_password_here
DB_PORT=6543

# ── Redis (Upstash) ───────────────────────────────────────────
# Use the Redis password from the Upstash console (TLS endpoint),
# NOT the REST API token.
REDIS_HOST=your-db.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_SSL=true

# ── JWT ───────────────────────────────────────────────────────
# Must be at least 32 chars. Use: openssl rand -hex 32
JWT_SECRET=generate_with_openssl_rand_hex_32

# ── Spring Profile ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Email (Resend via SMTP) ───────────────────────────────────
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key_here

# ── App base URL (used in email links) ────────────────────────
APP_BASE_URL=https://app.gridclanpuzzle.win

# ── Firebase Cloud Messaging (push notifications) ─────────────
# Get from Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key_here

# ── Relworx (mobile-money gem purchases) ──────────────────────
# Get the API key + account number from the Relworx dashboard. The webhook
# secret is the "webhook authentication key" shown when you register the
# webhook URL (Developer/API → Webhooks) — NOT the API key. Leave RELWORX_API_KEY
# blank to keep the gem store turned off. The webhook URL must match EXACTLY what
# you register in the Relworx dashboard (it is part of the signed payload).
RELWORX_API_KEY=your_relworx_api_key_here
RELWORX_ACCOUNT_NO=your_relworx_account_no_here
RELWORX_WEBHOOK_SECRET=your_relworx_webhook_signing_key_here
RELWORX_WEBHOOK_URL=https://api.gridclanpuzzle.win/payments/relworx/webhook
# Header names Relworx sends the signature + timestamp in (adjust if their docs
# or a real webhook show different names — the server logs the names it receives).
RELWORX_SIGNATURE_HEADER=Relworx-Signature
RELWORX_TIMESTAMP_HEADER=Relworx-Timestamp

# ── Sentry (error tracking) ───────────────────────────────────
# A DSN is already baked into application.yml as the default, so crash
# reporting works without setting anything here. Set SENTRY_DSN to override
# (e.g. a separate Sentry project per environment). A DSN is a write-only
# ingest key — safe to commit. SENTRY_ENV tags events (production/staging/dev).
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
SENTRY_ENV=production
