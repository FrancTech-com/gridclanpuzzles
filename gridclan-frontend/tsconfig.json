{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@theme/*": ["src/theme/*"],
      "@store/*": ["src/store/*"],
      "@api/*": ["src/api/*"],
      "@hooks/*": ["src/hooks/*"],
      "@components/*": ["src/components/*"],
      "@gridtypes/*": ["src/types/*"],
      "@websocket/*": ["src/websocket/*"],
      "@utils/*": ["src/utils/*"],
      "@services/*": ["src/services/*"],
      "@i18n/*": ["src/i18n/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
